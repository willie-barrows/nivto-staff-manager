                            <strong>Annual</strong>
                            <span class="price">R3,588</span>
                        </div>
                        <small style="color: #27ae60;">Save 15%</small>
                    </label>
                    
                    <h3>Your Details:</h3>
                    <input type="text" id="name" name="name" placeholder="Full Name" required>
                    <input type="email" id="email" name="email" placeholder="Email Address" required>
                    <input type="tel" id="phone" name="phone" placeholder="Phone Number (e.g., 0743532291)" required>
                    
                    <div class="error" id="errorMessage"></div>
                    
                    <button type="submit" id="submitBtn">🔒 Pay Securely with Yoco</button>
