                const yoco = new window.YocoSDK({
                    publicKey: '${CONFIG.YOCO.PUBLIC_KEY}'
                });
                
                const form = document.getElementById('paymentForm');
                const submitBtn = document.getElementById('submitBtn');
                const errorMessage = document.getElementById('errorMessage');
                
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    // Get form values
                    const name = document.getElementById('name').value;
                    const email = document.getElementById('email').value;
                    const phone = document.getElementById('phone').value;
                    const selectedPlan = document.querySelector('input[name="plan"]:checked');
                    const amount = parseInt(selectedPlan.dataset.amount);
                    const plan = selectedPlan.value;
                    
                    // Disable button and show loading
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<div class="spinner"></div>';
                    errorMessage.style.display = 'none';
                    
                    try {
                        // Create Yoco payment popup
                        yoco.showPopup({
                            amountInCents: amount,
                            currency: 'ZAR',
                            name: 'NIVTO Staff Manager',
                            description: \`\${selectedPlan.value.charAt(0).toUpperCase() + selectedPlan.value.slice(1)} Subscription\`,
                            metadata: {
                                customerName: name,
                                customerEmail: email,
                                customerPhone: phone,
                                plan: plan
                            },
                            callback: function (result) {
                                if (result.error) {
                                    errorMessage.textContent = result.error.message;
                                    errorMessage.style.display = 'block';
                                    submitBtn.disabled = false;
                                    submitBtn.innerHTML = '🔒 Pay Securely with Yoco';
                                } else {
                                    // Payment successful - send to server
                                    fetch('/process-payment', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({
                                            token: result.id,
                                            name: name,
                                            email: email,
                                            phone: phone,
                                            plan: plan,
                                            amount: amount
                                        })
                                    })
                                    .then(res => res.json())
                                    .then(data => {
                                        if (data.success) {
                                            window.location.href = '/payment-success?email=' + encodeURIComponent(email);
                                        } else {
                                            throw new Error(data.message || 'Payment processing failed');
                                        }
                                    })
                                    .catch(err => {
                                        errorMessage.textContent = err.message;
                                        errorMessage.style.display = 'block';
                                        submitBtn.disabled = false;
                                        submitBtn.innerHTML = '🔒 Pay Securely with Yoco';
                                    });
                                }
                            }
                        });
                    } catch (error) {
                        errorMessage.textContent = error.message;
                        errorMessage.style.display = 'block';
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '🔒 Pay Securely with Yoco';
                    }
                });
            </script>
        </body>
        </html>
    `);
});

// Process Yoco payment
app.post('/process-payment', async (req, res) => {
    const { token, name, email, phone, plan, amount } = req.body;
    
    console.log('Processing Yoco payment:', { email, plan, amount });
    
    try {
        // Determine duration based on plan
        let days, planName;
        switch(plan) {
            case 'monthly':
                days = 30;
                planName = 'Monthly Subscription';
                break;
            case 'quarterly':
                days = 90;
                planName = '3-Month Subscription';
                break;
            case 'annual':
                days = 365;
                planName = 'Annual Subscription';
                break;
            default:
                return res.status(400).json({ success: false, message: 'Invalid plan' });
        }
        
        // Charge the payment with Yoco
        const https = require('https');
        const chargeData = JSON.stringify({
            token: token,
            amountInCents: amount,
            currency: 'ZAR',
            metadata: {
                customerName: name,
                customerEmail: email,
                customerPhone: phone,
                plan: plan,
                planName: planName,
                days: days
            }
        });
        
        const options = {
            hostname: 'online.yoco.com',
            port: 443,
            path: '/v1/charges/',
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Content-Length': chargeData.length,
                'Authorization': `Bearer ${CONFIG.YOCO.SECRET_KEY}`
            }
        };
        
        const chargePromise = new Promise((resolve, reject) => {
            const request = https.request(options, (response) => {
                let data = '';
                response.on('data', (chunk) => { data += chunk; });
                response.on('end', () => {
                    try {
                        const result = JSON.parse(data);
                        if (response.statusCode === 201) {
                            resolve(result);
                        } else {
                            reject(new Error(result.message || 'Payment failed'));
                        }
                    } catch (e) {
                        reject(new Error('Invalid response from payment gateway'));
                    }
                });
            });
            
            request.on('error', (error) => reject(error));
            request.write(chargeData);
            request.end();
        });
        
        const charge = await chargePromise;
        console.log('Yoco charge successful:', charge.id);
        
        // Generate license key
        const licenseKey = generateSubscriptionKey(days);
        
        // Calculate expiry date
        const expiryDate = new Date();
        expiryDate.setDate(expiryDate.getDate() + days);
        const expiryStr = expiryDate.toLocaleDateString('en-ZA');
        
        // Send email with license key
        await sendLicenseEmail(email, name, licenseKey, expiryStr, planName);
        
        // Log successful payment
        console.log(`Payment processed: ${email} - ${licenseKey}`);
        
        // TODO: Store in database for record keeping
        // await db.insertLicense({ email, licenseKey, expiryDate, customerName: name, chargeId: charge.id });
        
        res.json({ 
            success: true, 
            message: 'Payment successful',
            licenseKey: licenseKey 
        });
        
    } catch (error) {
        console.error('Payment processing error:', error);
        res.status(500).json({ 
            success: false, 
            message: error.message || 'Payment processing failed' 
        });
    }
});

