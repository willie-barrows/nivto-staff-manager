// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function generatePayFastSignature(data) {
    // Remove signature if present
    const { signature, ...dataToSign } = data;
    
    // Create parameter string
    let paramString = '';
    for (const key of Object.keys(dataToSign).sort()) {
        if (dataToSign[key] !== '') {
            paramString += `${key}=${encodeURIComponent(dataToSign[key]).replace(/%20/g, '+')}&`;
        }
    }
    
    // Remove trailing ampersand
    paramString = paramString.slice(0, -1);
    
    // Add passphrase if in production
    if (!CONFIG.PAYFAST.SANDBOX && CONFIG.PAYFAST.PASSPHRASE) {
        paramString += `&passphrase=${encodeURIComponent(CONFIG.PAYFAST.PASSPHRASE)}`;
    }
    
    // Generate MD5 signature
    return crypto.createHash('md5').update(paramString).digest('hex');
}

async function sendLicenseEmail(recipientEmail, customerName, licenseKey, expiryDate, planName) {
    const htmlContent = getLicenseEmailHtml(customerName, licenseKey, expiryDate, planName);
    
    const mailOptions = {
        from: CONFIG.EMAIL.FROM,
        to: recipientEmail,
        subject: '🎉 Your NIVTO Staff Manager License Key',
        html: htmlContent,
        text: `
Hello ${customerName},

Your NIVTO Staff Manager license key: ${licenseKey}
Valid until: ${expiryDate}

To activate:
1. Install NIVTO Staff Manager
2. Enter your license key when prompted (Yoco Integration)');
    console.log('='.repeat(60));
    console.log(`Server running on port ${CONFIG.PORT}`);
    console.log(`Environment: ${CONFIG.YOCO.MODE.toUpperCase()}`);
    console.log(`Base URL: ${CONFIG.BASE_URL}`);
    console.log(`Payment Provider: Yoco`);
    console.log('');
    console.log('Webhook URL for Yoco (optional):');
    console.log(`  ${CONFIG.BASE_URL}/webhook/yoco`);
    console.log('');
    console.log('Payment page:');
    console.log(`  ${CONFIG.BASE_URL}/`);
    console.log('');
    console.log('⚠️  Make sure YOCO_PUBLIC_KEY and YOCO_SECRET_KEY are set in .env'ions);
}

