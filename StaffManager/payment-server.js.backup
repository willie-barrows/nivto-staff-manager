/**
 * NIVTO Staff Manager - Automated Payment Server
 * 
 * This Express server handles:
 * - Payment processing via PayFast/Paystack
 * - Automatic license key generation
 * - Email delivery to customers
 * - Webhook handling for payment confirmations
 * - Recurring subscription management
 * 
 * Setup Instructions:
 * 1. npm install express body-parser nodemailer
 * 2. Configure your payment provider credentials below
 * 3. Set up your email SMTP settings
 * 4. Deploy to a server (e.g., Heroku, DigitalOcean, AWS)
 * 5. Configure webhook URL in your payment provider dashboard
 */

const express = require('express');
const bodyParser = require('body-parser');
const crypto = require('crypto');
const nodemailer = require('nodemailer');
const { generateLicenseKey } = require('./generate-license');

const app = express();
app.use(bodyParser.json());
app.use(bodyParser.urlencoded({ extended: true }));

// ============================================================================
// CONFIGURATION - Update these with your actual credentials
// ============================================================================

const CONFIG = {
    // Server Settings
    PORT: process.env.PORT || 3000,
    BASE_URL: process.env.BASE_URL || 'https://your-domain.com',
    
    // Yoco Configuration (South African)
    YOCO: {
        SECRET_KEY: process.env.YOCO_SECRET_KEY || 'your_secret_key',
        PUBLIC_KEY: process.env.YOCO_PUBLIC_KEY || 'your_public_key',
        API_URL: process.env.NODE_ENV === 'production' 
            ? 'https://online.yoco.com/v1' 
            : 'https://online.yoco.com/v1', // Yoco doesn't have separate sandbox
        MODE: process.env.NODE_ENV !== 'production' ? 'test' : 'live'
    },
    
    // Email Configuration (for sending license keys)
    EMAIL: {
        SERVICE: 'gmail', // or 'smtp'
        HOST: process.env.EMAIL_HOST || 'smtp.gmail.com',
        PORT: 587,
        SECURE: false,
        AUTH: {
            USER: process.env.EMAIL_USER || 'your-email@gmail.com',
            PASS: process.env.EMAIL_PASSWORD || 'your-app-password'
        },
        FROM: process.env.EMAIL_FROM || 'NIVTO Staff Manager <noreply@nivto.com>'
    },
    
    // Subscription Pricing (in ZAR)
    PRICING: {
        MONTHLY: 349,
        QUARTERLY: 947,    // 3 months - can add discount
        BIANNUAL: 1794,    // 6 months - can add discount
        ANNUAL: 3588       // 12 months - can add discount
    }
};

// ============================================================================
// EMAIL CONFIGURATION
// ============================================================================

const transporter = nodemailer.createTransport({
    host: CONFIG.EMAIL.HOST,
    port: CONFIG.EMAIL.PORT,
    secure: CONFIG.EMAIL.SECURE,
    auth: {
        user: CONFIG.EMAIL.AUTH.USER,
        pass: CONFIG.EMAIL.AUTH.PASS
    }
});

// ============================================================================
// LICENSE KEY GENERATION
// ============================================================================

function generateSubscriptionKey(daysValid) {
    const expiryDate = new Date();
    expiryDate.setDate(expiryDate.getDate() + daysValid);
    
    const year = expiryDate.getFullYear();
    const month = String(expiryDate.getMonth() + 1).padStart(2, '0');
    const day = String(expiryDate.getDate()).padStart(2, '0');
    const dateStr = `${year}${month}${day}`;
    
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let code = '';
    for (let i = 0; i < 5; i++) {
        code += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    
    return `NIVTO-SUB-${dateStr}-${code}`;
}

