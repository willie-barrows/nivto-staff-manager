# NIVTO Staff Manager - Payment Server Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ============================================================================
# YOCO CREDENTIALS
# Get these from: https://portal.yoco.com/online/settings/api-keys
# ============================================================================

# Test Credentials (Use for development/testing)
# Get from: https://portal.yoco.com/online/settings/api-keys
YOCO_SECRET_KEY=sk_test_your_test_secret_key_here
YOCO_PUBLIC_KEY=pk_test_your_test_public_key_here

# Production Credentials (uncomment and fill in for live payments)
# YOCO_SECRET_KEY=sk_live_your_live_secret_key_here
# YOCO_PUBLIC_KEY=pk_live_your_live_public_key_here

# ============================================================================
# EMAIL CONFIGURATION
# For sending license keys to customers
# ============================================================================

# Gmail Configuration (Recommended for getting started)
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use that app password below (not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM="NIVTO Staff Manager <noreply@nivto.com>"

# Alternative: SendGrid (for high volume)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your_sendgrid_api_key
# EMAIL_FROM="NIVTO Staff Manager <noreply@nivto.com>"

# Alternative: Custom SMTP Server
# EMAIL_HOST=mail.yourdomain.com
# EMAIL_PORT=587
# EMAIL_USER=noreply@yourdomain.com
# EMAIL_PASSWORD=your_email_password
# EMAIL_FROM="NIVTO Staff Manager <noreply@yourdomain.com>"

# ============================================================================
# SUBSCRIPTION PRICING (in ZAR)
# ============================================================================
PRICE_MONTHLY=349
PRICE_QUARTERLY=947
PRICE_BIANNUAL=1794
PRICE_ANNUAL=3588

# ============================================================================
# SECURITY (Optional but Recommended)
# ============================================================================
# Generate a random string for session security
# SESSION_SECRET=your_random_secret_here

# JWT secret for API authentication (if you add customer portal)
# JWT_SECRET=your_jwt_secret_here

# ============================================================================
# DATABASE (Optional - for storing customer records)
# ============================================================================
# DATABASE_PATH=./data/licenses.db

# ============================================================================
# NOTES
# ============================================================================
# - Never commit this file to version control
# - Keep your credentials secure
# - Use sandbox mode for testing
# - Switch to production credentials only when ready to go live
# - See PAYMENT_SETUP_GUIDE.md for detailed setup instructions
